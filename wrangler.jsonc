{
  "name": "cgr-30p-log-viewer",
  "main": "src/worker.ts",
  "compatibility_date": "2025-01-01",
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "vars": {
    "BASE_PATH": "/"
  },
  "routes": [
    {
      "pattern": "gefc.kaarvik.com",
      "custom_domain": true
    }
  ],
  "r2_buckets": [
    {
      "binding": "gefc_logs",
      "bucket_name": "gefc-logs"
    }
  ]
}
